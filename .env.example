# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=privacy_audit

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Change this to a long random string in production.
# All JWTs (tenant admin, dashboard handshake, dashboard session) are signed
# with this secret. The `type` claim in each payload ensures tokens issued for
# one purpose cannot be used for another.
JWT_SECRET=change-me-use-a-long-random-string-in-production

# ─── Dashboard ───────────────────────────────────────────────────────────────
# Base URL of the privacy dashboard frontend. Used to construct the redirect
# URL returned by POST /api/dashboard/token.
DASHBOARD_BASE_URL=http://localhost:3000

# ─── Service ──────────────────────────────────────────────────────────────────
PORT=8080
