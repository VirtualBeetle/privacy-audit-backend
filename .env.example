# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=privacy_audit

# ─── Redis (BullMQ queue) ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
# All JWTs (tenant admin, dashboard handshake, dashboard_session, google_session)
# share this secret. The `type` claim in each payload prevents cross-use.
JWT_SECRET=change-me-use-a-long-random-string-in-production

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Register at https://console.cloud.google.com/ → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# ─── Dashboard ─────────────────────────────────────────────────────────────────
# Base URL of the privacy dashboard frontend. Used to construct redirect URLs.
DASHBOARD_BASE_URL=http://localhost:3000

# ─── AI Risk Agent ─────────────────────────────────────────────────────────────
# Anthropic API key for Claude-powered privacy risk analysis.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── MongoDB (AI Chat + AI Analysis storage) ──────────────────────────────────
# Local Docker:  mongodb://localhost:27017/privacy_audit_ai
# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/privacy_audit_ai
MONGODB_URI=mongodb://localhost:27017/privacy_audit_ai

# ─── Email (Nodemailer) ────────────────────────────────────────────────────────
# Gmail SMTP:  smtp.gmail.com / 587 (use App Password, not account password)
# Mailtrap:    sandbox.smtp.mailtrap.io / 2525  (great for testing, free)
# SendGrid:    smtp.sendgrid.net / 587
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
FROM_EMAIL=privacy-audit@yourdomain.com

# ─── Developer Tools (manual triggers for demo) ────────────────────────────────
# Set to any random secret. Guards the /api/dev/* endpoints.
# Generate one: openssl rand -hex 32
DEV_TOKEN=change-me-dev-token

# ─── Service ───────────────────────────────────────────────────────────────────
PORT=8080
